server {
    listen 443 ssl;
    server_name 107.21.31.183;
    ssl_certificate /etc/nginx/pritunl-nginx.crt;
    ssl_certificate_key /etc/nginx/pritunl-nginx.key;
    large_client_header_buffers 4 32k;
    client_header_buffer_size 32k;

    location = /login {
        return 200 '<!DOCTYPE html><html><head><title>Pritunl Login</title>
        <style>body{background:#1a1a1a;display:flex;justify-content:center;
        align-items:center;height:100vh;margin:0;}
        .btn{background:#428bca;color:#fff;padding:15px 40px;font-size:18px;
        border:none;border-radius:4px;cursor:pointer;text-decoration:none;
        font-family:Arial,sans-serif;}</style></head>
        <body><a class="btn" href="/sso">Sign in with SSO</a></body></html>';
        add_header Content-Type text/html;
    }

    location = /sso {
        return 302 https://107.21.31.183:8443/sso/callback;
    }

    location = /settings {
        proxy_pass https://127.0.0.1:9443;
        proxy_ssl_verify off;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host 107.21.31.183;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header PR-Validated true;
        proxy_set_header PR-Forwarded-Url https://107.21.31.183$request_uri;
    }
    location = /saml/update {
        proxy_pass http://127.0.0.1:9756;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host 107.21.31.183;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header PR-Validated true;
        proxy_set_header PR-Forwarded-Url https://107.21.31.183$request_uri;
    }
    location /saml/ {
        proxy_pass http://127.0.0.1:9756;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host 107.21.31.183;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header PR-Forwarded-Url https://107.21.31.183$request_uri;
    }
    location = /saml-settings {
        proxy_pass http://127.0.0.1:9756;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host 107.21.31.183;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header PR-Forwarded-Url https://107.21.31.183/saml-settings;
    }
    location = /pritunl-admin {
        proxy_pass http://127.0.0.1:9756/login;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host 107.21.31.183;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header PR-Validated true;
        proxy_set_header PR-Forwarded-Url https://107.21.31.183/login;
    }

    location = /sso/callback {
        proxy_pass http://127.0.0.1:9756;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host 107.21.31.183;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header PR-Validated true;
        proxy_set_header PR-Forwarded-Url https://107.21.31.183:8443$request_uri;
    }


    # Pritunl API - proxied directly to Flask with auth headers preserved
    location ~ ^/user/ {
        proxy_pass http://127.0.0.1:9756;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host 107.21.31.183;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header PR-Validated true;
        proxy_set_header PR-Forwarded-Url https://107.21.31.183$request_uri;
    }

    location ~ ^/data/ {
        proxy_pass http://127.0.0.1:9756;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host 107.21.31.183;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header PR-Validated true;
        proxy_set_header PR-Forwarded-Url https://107.21.31.183$request_uri;
    }

    location ~ ^/key/ {
        proxy_pass https://127.0.0.1:9443;
        proxy_ssl_verify off;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host 107.21.31.183;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header PR-Forwarded-Url https://107.21.31.183$request_uri;
    }

    location / {
        proxy_pass https://127.0.0.1:9443;
        proxy_ssl_verify off;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host 107.21.31.183;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header PR-Forwarded-Url https://107.21.31.183$request_uri;
    }
}

